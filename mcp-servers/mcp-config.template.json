{
  "$comment": "Template for ~/.copilot/mcp-config.json or equivalent MCP configuration. Replace all <PLACEHOLDER> values with your actual credentials and paths.",
  "mcpServers": {
    "azure-devops": {
      "command": "npx",
      "args": ["-y", "@azure-devops/mcp@latest", "<YOUR_ADO_ORG_NAME>", "--authentication", "azcli"]
    },
    "azure-devops-remote": {
      "type": "http",
      "url": "https://mcp.dev.azure.com/<YOUR_ADO_ORG_NAME>"
    },
    "d365fo": {
      "command": "uvx",
      "args": ["--from", "d365fo-client@latest", "d365fo-fastmcp-server"],
      "env": {
        "D365FO_BASE_URL": "<YOUR_D365FO_URL>",
        "D365FO_TENANT_ID": "<YOUR_TENANT_ID>",
        "D365FO_LOG_LEVEL": "INFO"
      }
    },
    "devops-bridge": {
      "command": "node",
      "args": ["<PATH_TO>/devops-bridge/dist/index.js"],
      "env": {
        "AZURE_DEVOPS_ORG_URL": "<YOUR_ADO_ORG_URL>",
        "AZURE_DEVOPS_PAT": "<YOUR_PAT>",
        "JIRA_BASE_URL": "<YOUR_JIRA_URL>",
        "JIRA_EMAIL": "<YOUR_EMAIL>",
        "JIRA_API_TOKEN": "<YOUR_JIRA_TOKEN>",
        "CONFLUENCE_BASE_URL": "<YOUR_CONFLUENCE_URL>",
        "CONFLUENCE_EMAIL": "<YOUR_EMAIL>",
        "CONFLUENCE_API_TOKEN": "<YOUR_CONFLUENCE_TOKEN>"
      }
    },
    "spira": {
      "command": "node",
      "args": ["<PATH_TO>/spira-mcp-server/dist/index.js"],
      "env": {
        "SPIRA_URL": "<YOUR_SPIRA_URL>",
        "SPIRA_USER": "<YOUR_SPIRA_USER>",
        "SPIRA_API_KEY": "<YOUR_API_KEY>",
        "NODE_TLS_REJECT_UNAUTHORIZED": "0"
      }
    }
  }
}
